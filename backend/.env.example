# ============================================================
# GameAssetForge — AI 图像生成 Provider 配置
# ============================================================
# IMAGE_PROVIDER_MODE 可选值：
#   mock      — 默认，程序化生成（Pillow），无需任何 API Key
#   http      — 调用远程 AI 图像生成 HTTP API
# ============================================================
IMAGE_PROVIDER_MODE=mock

# ============================================================
# 通用 HTTP Provider 配置
# ============================================================
# IMAGE_PROVIDER_BACKEND 可选值：
#   auto      — 自动检测（推荐，从 ENDPOINT URL 推断）
#   sd_webui  — Stable Diffusion WebUI / Forge
#   comfyui   — ComfyUI
#   openai    — OpenAI 兼容 API（DALL-E / SiliconFlow / Novita 等）
#   generic   — 通用 JSON POST
# ============================================================
IMAGE_PROVIDER_BACKEND=auto
IMAGE_PROVIDER_ENDPOINT=
IMAGE_PROVIDER_API_KEY=
IMAGE_PROVIDER_MODEL=
IMAGE_PROVIDER_TIMEOUT=120

# ============================================================
# SD WebUI / ComfyUI 生成参数（可调）
# ============================================================
IMAGE_PROVIDER_STEPS=20
IMAGE_PROVIDER_CFG=7.0
IMAGE_PROVIDER_SAMPLER=Euler a

# ComfyUI 输出目录（本地文件模式需要）
# ComfyUI 默认输出路径为 ComfyUI/output/
# COMFYUI_OUTPUT_DIR=D:/ComfyUI_windows_portable/ComfyUI/output

# ============================================================
# 示例：Stable Diffusion WebUI (A1111 / Forge)
# ============================================================
# IMAGE_PROVIDER_MODE=http
# IMAGE_PROVIDER_BACKEND=sd_webui
# IMAGE_PROVIDER_ENDPOINT=http://localhost:7860/sdapi/v1/txt2img
# IMAGE_PROVIDER_API_KEY=

# ============================================================
# 示例：ComfyUI
# ============================================================
# IMAGE_PROVIDER_MODE=http
# IMAGE_PROVIDER_BACKEND=comfyui
# IMAGE_PROVIDER_ENDPOINT=http://localhost:8188/prompt
# COMFYUI_OUTPUT_DIR=D:/ComfyUI_windows_portable/ComfyUI/output

# ============================================================
# 示例：云端 API（SiliconFlow / Novita / OpenAI 等）
# ============================================================
# IMAGE_PROVIDER_MODE=http
# IMAGE_PROVIDER_BACKEND=generic
# IMAGE_PROVIDER_ENDPOINT=https://api.siliconflow.cn/v1/images/generations
# IMAGE_PROVIDER_API_KEY=sk-your-api-key-here
# IMAGE_PROVIDER_MODEL=stabilityai/stable-diffusion-3-5-large
